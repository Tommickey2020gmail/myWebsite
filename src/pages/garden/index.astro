---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostMeta from '../../components/PostMeta.astro';
import { slugHref } from '../../lib/url';

const notes = (await getCollection('garden', ({ data }) => !data.draft))
  .sort((a, b) => (b.data.updated ?? b.data.created).getTime() - (a.data.updated ?? a.data.created).getTime());
---
<BaseLayout title="花园 / Garden" description="Tommy 的数字花园：碎片想法、读书笔记、概念地图。Tommy's digital garden — fragmentary thoughts, reading notes, concept maps.">
  <h1 class="text-3xl mb-2"><span lang="zh">数字花园</span><span class="biling-sep" aria-hidden="true"> / </span><span lang="en">Digital Garden</span></h1>
  <p class="text-muted mb-8"><span lang="zh">一片不断生长的种子、嫩芽与常青植物。</span><span class="biling-sep" aria-hidden="true"> / </span><span lang="en">A growing collection of seeds, sprouts, and evergreens.</span></p>
  {notes.length === 0 ? (
    <p><span lang="zh">还没有种下任何笔记。</span><span class="biling-sep" aria-hidden="true"> / </span><span lang="en">No notes planted yet.</span></p>
  ) : (
    <ul class="space-y-6">
      {notes.map((n) => (
        <li>
          <a href={`/garden/${slugHref(n.id)}/`} class="block no-underline hover:text-accent">
            <h2 class="text-xl">{n.data.title}</h2>
            {n.data.title_en && n.data.title_en !== n.data.title && (
              <p class="text-sm text-muted" lang="en">{n.data.title_en}</p>
            )}
          </a>
          {n.data.description && <p class="text-sm text-muted mt-1">{n.data.description}</p>}
          {n.data.description_en && n.data.description_en !== n.data.description && (
            <p class="text-xs text-muted mt-1" lang="en">{n.data.description_en}</p>
          )}
          <div class="mt-2"><PostMeta created={n.data.created} updated={n.data.updated} status={n.data.status} kind="note" /></div>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
