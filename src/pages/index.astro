---
// src/pages/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroGraph from '../components/HeroGraph.astro';
import EegBand from '../components/EegBand.astro';
import { slugHref } from '../lib/url';

const allGarden = (await getCollection('garden', ({ data }) => !data.draft))
  .sort((a, b) => (b.data.updated ?? b.data.created).getTime() - (a.data.updated ?? a.data.created).getTime())
  .slice(0, 6);

const recentEssays = (await getCollection('essays', ({ data }) => !data.draft))
  .sort((a, b) => (b.data.updated ?? b.data.created).getTime() - (a.data.updated ?? a.data.created).getTime())
  .slice(0, 5);

const featuredProjects = (await getCollection('projects', ({ data }) => !data.draft && data.featured))
  .slice(0, 3);

const siteUrl = 'https://tommickey.cn';
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: "Tommy's Digital Garden",
    url: `${siteUrl}/`,
    inLanguage: ['zh-CN', 'en-US'],
    description: 'Tommy 的数字花园 — 哲学、AI、机器人、脑电反馈、心理学、科幻。',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Tommy',
    url: `${siteUrl}/`,
    email: 'tommickey2020@gmail.com',
    sameAs: ['https://github.com/Tommickey2020gmail'],
    knowsAbout: [
      'Philosophy',
      'Artificial Intelligence',
      'Robotics',
      'EEG Biofeedback',
      'Psychology',
      'Science Fiction',
    ],
  },
];
---
<BaseLayout title="首页 / Home" description="Tommy 的数字花园 — 哲学、AI、机器人、脑电反馈、心理学、科幻。Tommy's digital garden — philosophy, AI, robotics, EEG biofeedback, psychology, science fiction." jsonLd={jsonLd}>
  <section class="py-10">
    <div class="flex flex-col sm:flex-row sm:items-start sm:gap-8">
      <img
        src="/avatar.png"
        alt="Tommy 的卡通头像 / Tommy's cartoon avatar"
        width="144"
        height="144"
        class="w-28 h-28 sm:w-36 sm:h-36 rounded-full border border-border shadow-sm shrink-0 mb-6 sm:mb-0"
        loading="eager"
      />
      <div>
        <h1 class="text-4xl sm:text-5xl font-serif leading-tight mb-4">
          <span lang="zh">你好，我是 Tommy。</span><span class="biling-sep" aria-hidden="true"> / </span><span lang="en">Hi, I'm Tommy.</span>
        </h1>
        <p class="text-lg text-muted max-w-prose mb-4" lang="zh">
          我在<em>哲学</em>、<em>AI / 机器人</em>、<em>脑电生物反馈</em>、<em>心理学</em>与<em>科幻</em>的交汇处思考与制造。
          这是我的数字花园 —— 永远在生长，从未完工。
        </p>
        <p class="text-lg text-muted max-w-prose" lang="en">
          I think and build at the intersection of <em>philosophy</em>, <em>AI / robotics</em>,
          <em>EEG biofeedback</em>, <em>psychology</em>, and <em>science fiction</em>.
          This is my digital garden — perpetually growing, never finished.
        </p>
      </div>
    </div>
    <div class="mt-8"><HeroGraph /></div>
    <div class="mt-6"><EegBand /></div>
  </section>

  <section class="py-8">
    <div class="flex items-baseline justify-between mb-4">
      <h2 class="text-2xl font-serif"><span lang="zh">近期花园笔记</span><span class="biling-sep" aria-hidden="true"> / </span><span lang="en">Recent garden notes</span></h2>
      <a href="/garden/" class="text-sm"><span lang="zh">全部</span><span class="biling-sep" aria-hidden="true"> / </span><span lang="en">All</span> →</a>
    </div>
    {allGarden.length === 0 ? (
      <p class="text-muted"><span lang="zh">还没有笔记 — 第一批种子正在路上。</span><span class="biling-sep" aria-hidden="true"> / </span><span lang="en">No notes yet — first seedlings coming soon.</span></p>
    ) : (
      <ul class="space-y-3">
        {allGarden.map((note) => (
          <li>
            <a href={`/garden/${slugHref(note.id)}/`} class="block py-1 no-underline hover:text-accent">
              <span class="font-medium">{note.data.title}</span>
              {note.data.title_en && note.data.title_en !== note.data.title && (
                <span class="text-sm text-muted" lang="en"> · {note.data.title_en}</span>
              )}
              {note.data.description && (
                <span class="block text-sm text-muted">{note.data.description}</span>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  {recentEssays.length > 0 && (
    <section class="py-8">
      <div class="flex items-baseline justify-between mb-4">
        <h2 class="text-2xl font-serif"><span lang="zh">近期随笔</span><span class="biling-sep" aria-hidden="true"> / </span><span lang="en">Recent essays</span></h2>
        <a href="/essays/" class="text-sm"><span lang="zh">全部</span><span class="biling-sep" aria-hidden="true"> / </span><span lang="en">All</span> →</a>
      </div>
      <ul class="space-y-3">
        {recentEssays.map((e) => (
          <li>
            <a href={`/essays/${slugHref(e.id)}/`} class="block py-1 no-underline hover:text-accent">
              <span class="font-medium">{e.data.title}</span>
              {e.data.title_en && e.data.title_en !== e.data.title && (
                <span class="text-sm text-muted" lang="en"> · {e.data.title_en}</span>
              )}
              {e.data.description && (
                <span class="block text-sm text-muted">{e.data.description}</span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {featuredProjects.length > 0 && (
    <section class="py-8">
      <div class="flex items-baseline justify-between mb-4">
        <h2 class="text-2xl font-serif"><span lang="zh">精选项目</span><span class="biling-sep" aria-hidden="true"> / </span><span lang="en">Selected projects</span></h2>
        <a href="/projects/" class="text-sm"><span lang="zh">全部</span><span class="biling-sep" aria-hidden="true"> / </span><span lang="en">All</span> →</a>
      </div>
      <ul class="grid gap-4 sm:grid-cols-2">
        {featuredProjects.map((p) => (
          <li class="border border-border rounded-lg p-4">
            <a href={`/projects/${slugHref(p.id)}/`} class="font-medium no-underline">{p.data.title}</a>
            {p.data.title_en && p.data.title_en !== p.data.title && (
              <span class="text-sm text-muted" lang="en"> · {p.data.title_en}</span>
            )}
            {p.data.description && (
              <p class="mt-1 text-sm text-muted">{p.data.description}</p>
            )}
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>
