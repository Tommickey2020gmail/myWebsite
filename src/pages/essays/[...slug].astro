---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostMeta from '../../components/PostMeta.astro';
import Backlinks from '../../components/Backlinks.astro';
import Comments from '../../components/Comments.astro';
import { slugHref } from '../../lib/url';
import { readingStats } from '../../lib/reading';
import { getBacklinks } from '../../lib/backlinks';

export async function getStaticPaths() {
  const all = await getCollection('essays', ({ data }) => !data.draft);
  return all.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
const reading = readingStats(entry.body ?? '');
const backlinks = await getBacklinks('essays', entry.id);

const url = `https://tommickey.cn/essays/${slugHref(entry.id)}/`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.description,
  inLanguage: entry.data.lang === 'en' ? 'en-US' : 'zh-CN',
  datePublished: entry.data.created.toISOString(),
  dateModified: (entry.data.updated ?? entry.data.created).toISOString(),
  author: { '@type': 'Person', name: 'Tommy', url: 'https://tommickey.cn/' },
  keywords: entry.data.tags.join(', '),
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  url,
};
---
<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  lang={entry.data.lang}
  jsonLd={jsonLd}
  article={{
    publishedTime: entry.data.created,
    modifiedTime: entry.data.updated ?? entry.data.created,
    tags: entry.data.tags,
    section: 'Essays',
  }}
>
  <article class="prose prose-lg max-w-none">
    <header class="not-prose mb-6">
      <h1 class="text-3xl sm:text-4xl">{entry.data.title}</h1>
      {entry.data.title_en && entry.data.title_en !== entry.data.title && (
        <p class="mt-1 text-lg text-muted" lang="en">{entry.data.title_en}</p>
      )}
      <div class="mt-3"><PostMeta created={entry.data.created} updated={entry.data.updated} kind="essay" reading={reading} /></div>
    </header>
    <Content />
  </article>
  <Backlinks links={backlinks} />
  <Comments />
</BaseLayout>
