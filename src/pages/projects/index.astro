---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { slugHref } from '../../lib/url';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.created.getTime() - a.data.created.getTime());
---
<BaseLayout title="项目 / Projects" description="我做过的东西 — 机器人、脑电反馈、AI 工具、软硬件。Things I've built — robotics, EEG biofeedback, AI tools, software & hardware.">
  <h1 class="text-3xl mb-2">项目 / Projects</h1>
  <p class="text-muted mb-8">我真的动手做过的东西。 / Things I've actually built.</p>
  {projects.length === 0 ? (
    <p>还没有已发布的项目。 / No projects published yet.</p>
  ) : (
    <ul class="grid gap-4 sm:grid-cols-2">
      {projects.map((p) => (
        <li class="border border-border rounded-lg p-5">
          <a href={`/projects/${slugHref(p.id)}/`} class="block no-underline">
            <h2 class="text-xl">{p.data.title}</h2>
            {p.data.title_en && p.data.title_en !== p.data.title && (
              <p class="text-sm text-muted" lang="en">{p.data.title_en}</p>
            )}
          </a>
          {p.data.description && <p class="mt-2 text-sm text-muted">{p.data.description}</p>}
          {p.data.description_en && p.data.description_en !== p.data.description && (
            <p class="mt-1 text-xs text-muted" lang="en">{p.data.description_en}</p>
          )}
          {p.data.stack.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-1.5">
              {p.data.stack.map((s) => (
                <span class="text-xs px-2 py-0.5 rounded bg-border">{s}</span>
              ))}
            </div>
          )}
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
