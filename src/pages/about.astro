---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_URL } from '../lib/schema';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${SITE_URL}/#person`,
  name: 'Tommy',
  url: `${SITE_URL}/`,
  image: `${SITE_URL}/avatar.png`,
  description:
    'I think and build at the intersection of philosophy, AI, robotics, EEG biofeedback, psychology, dementia prevention, and science fiction.',
  jobTitle: 'Software engineer and independent researcher',
  email: 'tommickey2020@gmail.com',
  sameAs: [
    'https://github.com/Tommickey2020gmail',
    'https://www.zhihu.com/people/tommickey',
    'https://www.xiaohongshu.com/user/profile/6095f7a2000000000100799e',
  ],
  knowsAbout: [
    'Philosophy',
    'Artificial Intelligence',
    'Robotics',
    'EEG Biofeedback',
    'Psychology',
    'Dementia Prevention',
    'Science Fiction',
  ],
};

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  url: `${SITE_URL}/about/`,
  name: '关于 / About',
  description:
    'About Tommy — interests, work, and how to reach me. 关于 Tommy — 兴趣、工作和联系方式。',
  inLanguage: ['zh-CN', 'en-US'],
  mainEntity: { '@id': `${SITE_URL}/#person` },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'About', item: `${SITE_URL}/about/` },
  ],
};

const jsonLd = [personSchema, aboutPageSchema, breadcrumb];
---
<BaseLayout title="关于 / About" description="关于 Tommy — 兴趣、工作和联系方式。About Tommy — interests, work, and how to reach me." jsonLd={jsonLd}>
  <article class="prose prose-lg dark:prose-invert max-w-none">
    <h1><span lang="zh">关于</span><span class="biling-sep" aria-hidden="true"> / </span><span lang="en">About</span></h1>

    <h2 lang="zh">关于我</h2>
    <p lang="zh">
      我是 Tommy。我的兴趣在哲学、计算机软硬件、机器人、AI、脑电生物反馈专注力训练、心理学、
      老年痴呆预防、科幻小说交汇之处。这个网站是我公开的思考笔记。
    </p>
    <h3 lang="zh">我感兴趣的</h3>
    <ul lang="zh">
      <li><strong>哲学</strong> — 心智、意识、技术伦理</li>
      <li><strong>软硬件</strong> — 全栈、嵌入式、机器人</li>
      <li><strong>AI</strong> — 应用 LLM、智能体、对齐</li>
      <li><strong>脑电生物反馈</strong> — 专注力训练、认知增强</li>
      <li><strong>心理学</strong> — 认知科学、行为改变</li>
      <li><strong>老年痴呆预防</strong> — 生活方式、神经保护研究</li>
      <li><strong>科幻</strong> — 刘慈欣、Greg Egan、Ted Chiang</li>
    </ul>
    <h3 lang="zh">联系</h3>
    <ul lang="zh">
      <li>邮件：<a href="mailto:tommickey2020@gmail.com">tommickey2020@gmail.com</a></li>
      <li>GitHub：<a href="https://github.com/Tommickey2020gmail" target="_blank" rel="noopener noreferrer" aria-label="GitHub 主页 (在新标签页打开)">@Tommickey2020gmail <span aria-hidden="true">↗</span></a></li>
      <li>知乎：<a href="https://www.zhihu.com/people/tommickey" target="_blank" rel="noopener noreferrer" aria-label="知乎主页 (在新标签页打开)">@tommickey <span aria-hidden="true">↗</span></a></li>
      <li>小红书：<a href="https://www.xiaohongshu.com/user/profile/6095f7a2000000000100799e" target="_blank" rel="noopener noreferrer" aria-label="小红书主页 (在新标签页打开)">小红书主页 <span aria-hidden="true">↗</span></a></li>
    </ul>

    <hr />

    <h2 lang="en">English</h2>
    <p lang="en">
      I'm Tommy. I think and build at the intersection of philosophy, AI, robotics, EEG biofeedback,
      psychology, dementia prevention, and science fiction. This site is my open notebook.
    </p>
    <h3 lang="en">What I'm into</h3>
    <ul lang="en">
      <li><strong>Philosophy</strong> — mind, consciousness, ethics of technology</li>
      <li><strong>Software & hardware</strong> — full-stack, embedded, robotics</li>
      <li><strong>AI</strong> — applied LLMs, agents, alignment</li>
      <li><strong>EEG biofeedback</strong> — attention training, cognitive enhancement</li>
      <li><strong>Psychology</strong> — cognitive science, behavior change</li>
      <li><strong>Dementia prevention</strong> — lifestyle, neuroprotection research</li>
      <li><strong>Science fiction</strong> — Liu Cixin, Greg Egan, Ted Chiang</li>
    </ul>
    <h3 lang="en">Contact</h3>
    <ul lang="en">
      <li>Email: <a href="mailto:tommickey2020@gmail.com">tommickey2020@gmail.com</a></li>
      <li>GitHub: <a href="https://github.com/Tommickey2020gmail" target="_blank" rel="noopener noreferrer" aria-label="GitHub profile (opens in new tab)">@Tommickey2020gmail <span aria-hidden="true">↗</span></a></li>
      <li>Zhihu: <a href="https://www.zhihu.com/people/tommickey" target="_blank" rel="noopener noreferrer" aria-label="Zhihu profile (opens in new tab)">@tommickey <span aria-hidden="true">↗</span></a></li>
      <li>Xiaohongshu: <a href="https://www.xiaohongshu.com/user/profile/6095f7a2000000000100799e" target="_blank" rel="noopener noreferrer" aria-label="Xiaohongshu profile (opens in new tab)">Profile <span aria-hidden="true">↗</span></a></li>
    </ul>
  </article>
</BaseLayout>
