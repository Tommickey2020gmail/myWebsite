---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="搜索 / Search" description="在整个花园中搜索。Search across the entire garden.">
  <h1 class="text-3xl mb-2">搜索 / Search</h1>
  <p class="text-muted mb-6">在所有花园 / 随笔 / 项目内容中搜索。 Search across all garden / essays / projects content.</p>

  <input
    id="q"
    type="search"
    autofocus
    placeholder="输入关键词 / type to search…"
    aria-label="搜索查询 / Search query"
    class="w-full px-4 py-3 rounded-md border border-border bg-transparent text-base focus:outline-none focus:border-accent"
  />
  <p id="status" class="mt-3 text-sm text-muted">加载索引中… / Loading index…</p>
  <ul id="results" class="mt-6 space-y-4"></ul>

  <script is:inline>
    (async function () {
      const $q = document.getElementById('q');
      const $status = document.getElementById('status');
      const $results = document.getElementById('results');
      if (!$q || !$status || !$results) return;

      let index = null;
      try {
        const res = await fetch('/search-index.json');
        index = await res.json();
        $status.textContent = `已索引 ${index.length} 条 / Indexed ${index.length} entries.`;
      } catch (err) {
        $status.textContent = '加载索引失败 / Failed to load index.';
        return;
      }

      const kindLabel = { garden: '花园 / Garden', essays: '随笔 / Essay', projects: '项目 / Project' };

      function score(entry, tokens) {
        // Higher is better. Title hits weigh more than description than body.
        // Both zh + en titles/descriptions are scored so either language matches.
        let s = 0;
        const t = entry.title.toLowerCase();
        const tEn = (entry.title_en || '').toLowerCase();
        const d = (entry.description || '').toLowerCase();
        const dEn = (entry.description_en || '').toLowerCase();
        const b = entry.body.toLowerCase();
        const tags = (entry.tags || []).map(function (x) { return x.toLowerCase(); });
        for (const tok of tokens) {
          if (!tok) continue;
          if (t.includes(tok)) s += 8;
          if (tEn.includes(tok)) s += 8;
          if (d.includes(tok)) s += 4;
          if (dEn.includes(tok)) s += 4;
          if (tags.some(function (x) { return x.includes(tok); })) s += 5;
          if (b.includes(tok)) s += 1;
        }
        return s;
      }

      function snippet(entry, tokens) {
        const body = entry.body;
        const lower = body.toLowerCase();
        let bestIdx = -1;
        for (const tok of tokens) {
          if (!tok) continue;
          const i = lower.indexOf(tok);
          if (i >= 0 && (bestIdx < 0 || i < bestIdx)) bestIdx = i;
        }
        if (bestIdx < 0) return body.slice(0, 140);
        const start = Math.max(0, bestIdx - 40);
        const end = Math.min(body.length, bestIdx + 140);
        return (start > 0 ? '…' : '') + body.slice(start, end) + (end < body.length ? '…' : '');
      }

      function escapeHtml(s) {
        return s.replace(/[&<>"']/g, function (c) {
          return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
        });
      }

      function highlight(text, tokens) {
        // Escape first, then wrap matches in <mark>. Tokens are already lowercased.
        let html = escapeHtml(text);
        for (const tok of tokens) {
          if (!tok) continue;
          const safe = tok.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
          html = html.replace(new RegExp('(' + safe + ')', 'gi'), '<mark>$1</mark>');
        }
        return html;
      }

      function render(query) {
        const tokens = query.toLowerCase().split(/\s+/).filter(Boolean);
        $results.innerHTML = '';
        if (!tokens.length) { $status.textContent = `已索引 ${index.length} 条 / Indexed ${index.length} entries.`; return; }
        const ranked = index
          .map(function (e) { return { e: e, s: score(e, tokens) }; })
          .filter(function (x) { return x.s > 0; })
          .sort(function (a, b) { return b.s - a.s; })
          .slice(0, 30);
        $status.textContent = ranked.length + ' 条结果 / result' + (ranked.length === 1 ? '' : 's');
        for (const { e } of ranked) {
          const li = document.createElement('li');
          li.innerHTML =
            '<a href="' + e.href + '" class="block py-2 no-underline hover:text-accent">' +
              '<span class="text-xs text-muted uppercase tracking-wider mr-2">' + (kindLabel[e.kind] || e.kind) + '</span>' +
              '<span class="font-medium">' + highlight(e.title, tokens) + '</span>' +
              (e.description ? '<p class="text-sm text-muted mt-1">' + highlight(e.description, tokens) + '</p>' : '') +
              '<p class="text-xs text-muted mt-1">' + highlight(snippet(e, tokens), tokens) + '</p>' +
            '</a>';
          $results.appendChild(li);
        }
      }

      let timer = null;
      $q.addEventListener('input', function () {
        clearTimeout(timer);
        timer = setTimeout(function () { render($q.value.trim()); }, 80);
      });
      // Pre-fill from ?q=
      const u = new URL(location.href);
      const q0 = u.searchParams.get('q');
      if (q0) { $q.value = q0; render(q0); }
    })();
  </script>
</BaseLayout>
