---
// src/components/Footer.astro
const year = new Date().getFullYear();
---
<footer class="border-t border-border mt-16">
  <div class="mx-auto max-w-3xl px-5 sm:px-6 py-8 text-sm text-muted flex flex-wrap justify-between gap-4">
    <span>© {year} Tommy · Cultivated in the open</span>
    <div class="flex flex-wrap gap-4">
      <a href="/random/" class="hover:text-accent">Random</a>
      <a href="/rss.xml" class="hover:text-accent">RSS</a>
      <a href="/sitemap-index.xml" class="hover:text-accent">Sitemap</a>
      <span class="hidden sm:inline">Press <kbd class="px-1.5 py-0.5 border border-border rounded text-xs">/</kbd> to search</span>
    </div>
  </div>
</footer>
