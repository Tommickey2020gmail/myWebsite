---
// src/components/LangSwitch.astro
import { detectLang, localizePath } from "../lib/i18n";

const currentLang = detectLang(Astro.url.pathname);
const targetLang = currentLang === 'en' ? 'zh' : 'en';
const targetPath = localizePath(Astro.url.pathname, targetLang);
---
<a
  href={targetPath}
  class="inline-flex items-center justify-center min-w-[44px] min-h-[44px] rounded-md text-sm text-muted hover:text-accent hover:bg-border transition-colors no-underline"
  aria-label={currentLang === 'en' ? '切换到中文' : 'Switch to English'}
>
  {currentLang === 'en' ? '中' : 'EN'}
</a>
