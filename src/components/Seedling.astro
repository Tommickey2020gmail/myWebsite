---
// src/components/Seedling.astro
// Tiny animated leaf icon, used to visually mark a "seedling" garden note.
// 14px, inherits color, gently sways. Respects prefers-reduced-motion.
---
<svg class="seedling" width="14" height="14" viewBox="0 0 24 24"
     fill="none" stroke="currentColor" stroke-width="1.6"
     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <path d="M12 22V11" />
  <path d="M12 11C12 6 16 4 20 4C20 9 17 13 12 13" />
  <path d="M12 13C12 9 9 7 5 7C5 11 7 14 12 14" />
</svg>

<style>
  .seedling {
    display: inline-block;
    vertical-align: -2px;
    color: var(--color-secondary);
    transform-origin: 12px 22px;
    animation: seedling-sway 6s ease-in-out infinite;
  }
  @keyframes seedling-sway {
    0%, 100% { transform: rotate(-4deg); }
    50%      { transform: rotate(4deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .seedling { animation: none; }
  }
</style>
