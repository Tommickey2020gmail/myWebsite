---
import QRCode from 'qrcode';

interface Props {
  title: string;
  description?: string;
  path: string; // e.g. "/essays/foo/"
}
const { title, description = '', path } = Astro.props;
const fullUrl = `https://tommickey.cn${path}`;
const qrSvg = await QRCode.toString(fullUrl, {
  type: 'svg',
  margin: 1,
  color: { dark: '#1f1d1a', light: '#ffffff' },
});

const encUrl = encodeURIComponent(fullUrl);
const encTitle = encodeURIComponent(title);
const encSummary = encodeURIComponent(description);

const weiboUrl = `https://service.weibo.com/share/share.php?url=${encUrl}&title=${encTitle}&pic=&searchPic=false`;
const qzoneUrl = `https://sns.qzone.qq.com/cgi-bin/qzshare/cgi_qzshare_onekey?url=${encUrl}&title=${encTitle}&summary=${encSummary}&desc=${encSummary}`;
const qqUrl = `https://connect.qq.com/widget/shareqq/index.html?url=${encUrl}&title=${encTitle}&summary=${encSummary}`;
const twitterUrl = `https://twitter.com/intent/tweet?url=${encUrl}&text=${encTitle}`;
---
<aside class="not-prose mt-10 border-t border-border pt-6">
  <div class="share-bar">
    <span class="share-label">
      <span lang="zh">分享到</span><span class="biling-sep" aria-hidden="true"> / </span><span lang="en">Share</span>
    </span>

    {/* WeChat — QR popover */}
    <span class="share-pop-wrap" data-share-popover-wrap>
      <button type="button" class="share-icon" aria-label="微信 / WeChat" data-share-popover-toggle>
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M8.69 2.19C3.89 2.19 0 5.48 0 9.53c0 2.21 1.17 4.2 3 5.55a.59.59 0 0 1 .21.66l-.39 1.48c-.02.07-.05.14-.05.21 0 .16.13.3.29.3.06 0 .12-.02.17-.06l1.9-1.11a.86.86 0 0 1 .72-.1c.91.27 1.87.4 2.84.4.27 0 .54-.02.81-.04-.86-2.58.16-4.97 1.93-6.45 1.7-1.41 3.88-1.98 5.85-1.84-.49-3.01-3.88-5.35-7.59-5.35zM5.79 5.99a1.18 1.18 0 1 1 0 2.36 1.18 1.18 0 0 1 0-2.36zm5.81 0a1.18 1.18 0 1 1 0 2.36 1.18 1.18 0 0 1 0-2.36zm5.34 2.87c-1.8-.05-3.75.51-5.28 1.79-1.72 1.43-2.69 3.72-1.78 6.22.94 2.45 3.67 4.23 6.88 4.23.83 0 1.62-.12 2.36-.34a.72.72 0 0 1 .6.08l1.58.93c.04.02.09.04.14.04.13 0 .24-.11.24-.25 0-.06-.02-.12-.04-.18l-.33-1.23a.58.58 0 0 1 .12-.55c1.52-1.18 2.53-2.85 2.53-4.76 0-3.34-3.07-6.04-6.81-5.99zM14.34 12.6a.97.97 0 1 1 0 1.95.97.97 0 0 1 0-1.95zm4.84 0a.97.97 0 1 1 0 1.95.97.97 0 0 1 0-1.95z"/>
        </svg>
      </button>
      <div class="share-popover" hidden>
        <div class="share-qr" set:html={qrSvg} />
        <p class="share-pop-tip">
          <span lang="zh">微信扫码后<br/>可分享到朋友圈</span>
          <span lang="en">Scan with WeChat<br/>then share to Moments</span>
        </p>
      </div>
    </span>

    {/* Weibo */}
    <a href={weiboUrl} target="_blank" rel="noopener noreferrer" class="share-icon" aria-label="微博 / Weibo" data-share-popup>
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M9.91 19.49c-3.94.39-7.34-1.39-7.59-3.97-.25-2.58 2.74-4.99 6.68-5.38 3.94-.39 7.34 1.39 7.59 3.97.25 2.58-2.74 4.99-6.68 5.38zm5.92-9.52c-.32-.1-.55-.16-.38-.59.37-.94.41-1.74.01-2.32-.75-1.07-2.81-1.02-5.16-.05 0 0-.74.32-.55-.27.36-1.16.31-2.13-.25-2.69-1.27-1.27-4.66.05-7.57 2.95C-.27 9.18-1.55 11.5 1.59 14.81 4.7 18.13 9.7 19 12.85 19c4.13 0 8.36-2.36 8.36-5.62 0-1.97-1.66-3.08-2.87-3.41h.5zm2.39-3.06c-.6-.66-1.49-.92-2.31-.74-.39.08-.64.46-.55.85.08.39.46.64.85.55.4-.09.83.04 1.12.36.29.32.37.76.21 1.14-.15.36.02.78.38.94.36.15.78-.02.94-.38.34-.81.17-1.74-.43-2.4l-.21-.32zm2.46-2.22c-1.23-1.36-3.04-1.88-4.71-1.51-.46.1-.75.55-.65 1.01.1.46.55.75 1.01.65 1.19-.26 2.48.1 3.36 1.07.88.97 1.13 2.31.74 3.5-.14.43.1.91.53 1.05.43.14.91-.1 1.05-.53.55-1.66.19-3.55-1.06-4.92l-.27-.32z"/>
        <ellipse cx="9.16" cy="14.91" rx="3.85" ry="2.96" fill="none"/>
      </svg>
    </a>

    {/* QZone */}
    <a href={qzoneUrl} target="_blank" rel="noopener noreferrer" class="share-icon" aria-label="QQ空间 / QZone" data-share-popup>
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M11.99 1.5l3.06 6.81 7.45.72-5.61 4.95 1.62 7.27-6.51-3.81-6.51 3.81 1.62-7.27L1.5 9.03l7.43-.72L11.99 1.5z"/>
      </svg>
    </a>

    {/* QQ */}
    <a href={qqUrl} target="_blank" rel="noopener noreferrer" class="share-icon" aria-label="QQ" data-share-popup>
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 1.6c-3.16 0-5.72 2.56-5.72 5.72v1.36c0 .73.16 1.43.44 2.06-1.31 1.59-2.95 4.43-2.95 7.74 0 1.5.43 2.86 1.16 3.34.49.32 1.06.18 1.42-.34l1.13-1.61c.5.53 1.18.94 1.95 1.18-.16.6-.25 1.27-.25 1.93 0 .51.41.92.92.92h7.8c.51 0 .92-.41.92-.92 0-.66-.09-1.33-.25-1.93.77-.24 1.45-.65 1.95-1.18l1.13 1.61c.36.52.93.66 1.42.34.73-.48 1.16-1.84 1.16-3.34 0-3.31-1.64-6.15-2.95-7.74.28-.63.44-1.33.44-2.06V7.32C17.72 4.16 15.16 1.6 12 1.6zm-2.5 6.4a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm5 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
      </svg>
    </a>

    {/* Twitter / X */}
    <a href={twitterUrl} target="_blank" rel="noopener noreferrer" class="share-icon" aria-label="X (Twitter)" data-share-popup>
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817-5.97 6.817H1.677l7.73-8.835L1.254 2.25h6.83l4.713 6.232 5.447-6.232zm-1.16 17.52h1.834L7.084 4.126H5.117l11.967 15.644z"/>
      </svg>
    </a>

    <span class="share-divider" aria-hidden="true"></span>

    {/* Copy link */}
    <button type="button" class="share-icon" data-share-copy={fullUrl} aria-label="复制链接 / Copy link">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
      </svg>
      <span class="share-toast" data-toast-zh="已复制" data-toast-en="Copied"></span>
    </button>

    {/* Native share — mobile only */}
    <button type="button" class="share-icon hidden" data-share-native data-title={title} data-text={description} data-url={fullUrl} aria-label="系统分享 / System share">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
        <polyline points="16 6 12 2 8 6"/>
        <line x1="12" y1="2" x2="12" y2="15"/>
      </svg>
    </button>
  </div>
</aside>

<style>
  .share-bar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .share-label {
    color: var(--color-muted);
    font-size: 0.875rem;
    margin-right: 0.5rem;
  }
  .share-icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 9999px;
    color: var(--color-muted);
    background: transparent;
    border: 1px solid transparent;
    cursor: pointer;
    text-decoration: none;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
  }
  .share-icon:hover {
    color: var(--color-accent);
    background: var(--color-border);
    border-color: var(--color-border);
  }
  .share-icon svg { width: 1.125rem; height: 1.125rem; }
  .share-divider {
    display: inline-block;
    width: 1px;
    height: 1.25rem;
    background: var(--color-border);
    margin: 0 0.25rem;
  }

  /* QR popover */
  .share-pop-wrap { position: relative; display: inline-block; }
  .share-popover {
    position: absolute;
    bottom: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    padding: 0.625rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.12);
    z-index: 20;
    width: 168px;
  }
  .share-popover[hidden] { display: none; }
  .share-pop-wrap:hover .share-popover,
  .share-pop-wrap.is-open .share-popover { display: block !important; }
  .share-popover .share-qr {
    background: white;
    padding: 0.25rem;
    border-radius: 0.25rem;
  }
  .share-popover .share-qr svg {
    display: block;
    width: 140px;
    height: 140px;
  }
  .share-pop-tip {
    text-align: center;
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-top: 0.5rem;
    line-height: 1.3;
  }
  /* arrow */
  .share-popover::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: var(--color-border);
  }

  /* Copy toast */
  .share-toast {
    position: absolute;
    bottom: calc(100% + 0.375rem);
    left: 50%;
    transform: translateX(-50%);
    padding: 0.25rem 0.5rem;
    background: var(--color-fg);
    color: var(--color-bg);
    font-size: 0.7rem;
    border-radius: 0.25rem;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }
  .share-icon.is-copied .share-toast { opacity: 1; }
</style>

<script>
  // Native share — mobile only
  document.querySelectorAll<HTMLButtonElement>('[data-share-native]').forEach((btn) => {
    if (typeof navigator !== 'undefined' && 'share' in navigator) {
      btn.classList.remove('hidden');
      btn.addEventListener('click', async () => {
        try {
          await (navigator as Navigator & { share: (d: ShareData) => Promise<void> }).share({
            title: btn.dataset.title,
            text: btn.dataset.text,
            url: btn.dataset.url,
          });
        } catch { /* user cancelled */ }
      });
    }
  });

  // Copy link with toast
  document.querySelectorAll<HTMLButtonElement>('[data-share-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.shareCopy ?? '';
      try {
        await navigator.clipboard.writeText(text);
        const toast = btn.querySelector<HTMLElement>('.share-toast');
        if (toast) {
          const en = document.documentElement.dataset.lang === 'en';
          toast.textContent = en ? (toast.dataset.toastEn ?? 'Copied') : (toast.dataset.toastZh ?? '已复制');
        }
        btn.classList.add('is-copied');
        setTimeout(() => btn.classList.remove('is-copied'), 1500);
      } catch { /* clipboard unavailable */ }
    });
  });

  // QR popover toggle (touch devices — hover handled by CSS)
  document.querySelectorAll<HTMLButtonElement>('[data-share-popover-toggle]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const wrap = btn.closest<HTMLElement>('[data-share-popover-wrap]');
      if (!wrap) return;
      // Close other open popovers
      document.querySelectorAll('[data-share-popover-wrap].is-open').forEach((w) => {
        if (w !== wrap) w.classList.remove('is-open');
      });
      wrap.classList.toggle('is-open');
    });
  });
  document.addEventListener('click', () => {
    document.querySelectorAll('[data-share-popover-wrap].is-open').forEach((w) => w.classList.remove('is-open'));
  });

  // Sized popup for share URLs
  document.querySelectorAll<HTMLAnchorElement>('[data-share-popup]').forEach((a) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      window.open(a.href, 'share-window', 'width=600,height=520,toolbar=0,menubar=0,location=0,status=0,scrollbars=1,resizable=1');
    });
  });
</script>
