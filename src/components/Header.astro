---
// src/components/Header.astro
import ThemeToggle from "./ThemeToggle.astro";

// Each link carries a Chinese label and an English label.
// Convention site-wide: Chinese first, English after, separated by ` / `.
const links = [
  { href: '/', zh: '首页', en: 'Home' },
  { href: '/garden/', zh: '花园', en: 'Garden' },
  { href: '/essays/', zh: '随笔', en: 'Essays' },
  { href: '/projects/', zh: '项目', en: 'Projects' },
  { href: '/library/', zh: '书房', en: 'Library' },
  { href: '/now/', zh: '近况', en: 'Now' },
  { href: '/tags/', zh: '标签', en: 'Tags' },
  { href: '/search/', zh: '搜索', en: 'Search' },
  { href: '/about/', zh: '关于', en: 'About' },
];

const current = Astro.url.pathname;
---
<header class="border-b border-border">
  <div class="mx-auto max-w-3xl px-5 sm:px-6 py-4 flex items-center justify-between gap-4">
    <a href="/" class="font-serif text-lg tracking-tight no-underline hover:opacity-80">
      Tommy
    </a>
    <nav class="flex items-center gap-4 overflow-x-auto" aria-label="Main navigation">
      {links.map(({ href, zh, en }) => (
        <a
          href={href}
          aria-label={`${zh} / ${en}`}
          class:list={[
            'text-sm whitespace-nowrap no-underline hover:text-accent',
            current === href || (href !== '/' && current.startsWith(href))
              ? 'text-accent'
              : 'text-fg',
          ]}
        >
          <span lang="zh">{zh}</span>
          <span class="biling-sep text-muted mx-1" aria-hidden="true">/</span>
          <span lang="en">{en}</span>
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-2">
      <button
        id="lang-toggle"
        type="button"
        class="lang-toggle text-sm text-fg hover:text-accent border border-border rounded px-2 py-1 leading-none"
        aria-label="切换中英文 / Toggle language"
        aria-pressed="false"
      >
        <span data-when="zh">EN</span>
        <span data-when="en">中</span>
      </button>
      <ThemeToggle />
    </div>
  </div>
</header>
